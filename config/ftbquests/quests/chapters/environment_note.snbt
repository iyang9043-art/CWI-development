		{
			dependencies: ["3CECF5ADD3C91E4B"]
			description: ["&eThe surface layer is dry, compacted, and lifeless. Stripped of organic matter and moisture by decades of solar radiation. It crumbles to dust when handled and holds no capacity to support even the hardiest microbes.&r"]
			hide_dependency_lines: true
			id: "5787AF3D0A2E4728"
			shape: "rsquare"
			size: 1.5d
			subtitle: "Powder and Dust"
